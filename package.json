{
  "name": "erp-cloud",
  "version": "1.0.0",
  "description": "Logiciel de gestion ERP pour boutique",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "next dev & sleep 3 && electron .",
    "electron:build": "cross-env BUILD_TARGET=electron next build && node scripts/copy-standalone.js",
    "electron:start": "electron .",
    "electron:prepare": "node -e \"require('fs').cpSync('.next/standalone','server-dist',{recursive:true})\"",
    "electron:dist": "cross-env BUILD_TARGET=electron next build && node scripts/copy-standalone.js && npm run electron:prepare && electron-builder build --win portable",
    "electron:dist-installer": "cross-env BUILD_TARGET=electron next build && node scripts/copy-standalone.js && npm run electron:prepare && electron-builder build --win nsis"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.3",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.erpcloud.app",
    "productName": "ERP Cloud",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "server-dist",
        "to": "app/server-dist",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": "server-dist/node_modules",
        "to": "app/server-dist/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": ".env.local",
        "to": "app/.env.local",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icons/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "language": "1044",
      "installerLanguages": [
        "fr-FR"
      ]
    },
    "portable": {
      "artifactName": "ERP-Cloud-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
